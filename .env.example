DATABASE_URL=postgresql://gameledger:gameledger@localhost:5432/gameledger
PORT=3001
SESSION_SECRET=change-me-in-production
NODE_ENV=development

# ── Ports ─────────────────────────────────────────────────────────────────────
# nginx is the primary entry point for BOTH stacks. Neither stack defaults to
# port 80.

# Production: nginx ingress port (docker-compose.yml)
APP_PORT=8080

# Dev: nginx ingress port — the ONLY host port published by the default dev stack.
#   docker compose -f docker-compose.dev.yml up --build
DEV_APP_PORT=8088

# Dev debug ports — OPT-IN via docker-compose.dev.debug.yml overlay.
# Not published in a plain `docker compose -f docker-compose.dev.yml up`.
# Use only when you need direct access to Vite, the NestJS API, or Postgres
# (e.g. connecting a DB client, hitting the backend without nginx, devtools on HMR).
#   docker compose -f docker-compose.dev.yml -f docker-compose.dev.debug.yml up --build
DEV_FRONTEND_PORT=5173
DEV_BACKEND_PORT=3001
DEV_DB_PORT=5432

POSTGRES_PASSWORD=gameledger

# ── Maintenance / Backups ──────────────────────────────────────────────────────
# Host-side path for the backup directory, bind-mounted into the backend container
# at /backups. May be a relative local path or an absolute path / NFS mountpoint.
# Examples:
#   BACKUP_HOST_DIR=./private_data/backups        (local, default)
#   BACKUP_HOST_DIR=/mnt/nfs/game-ledger-backups  (NFS mount)
BACKUP_HOST_DIR=./private_data/backups
